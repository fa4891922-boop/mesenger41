{
  "name": "pearnet-desktop",
  "version": "2.0.0",
  "description": "PearNet Messenger — Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently --kill-others \"cd ../frontend && npm run dev\" \"NODE_ENV=development electron .\"",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build": "electron-builder --linux --win"
  },
  "build": {
    "appId": "com.pearnet.messenger",
    "productName": "PearNet",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "icon.png"
    ],
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Network",
      "artifactName": "PearNet-v2-linux-${arch}.${ext}"
    },
    "win": {
      "target": [
        { "target": "zip", "arch": ["x64"] }
      ],
      "icon": "icon.ico",
      "sign": null,
      "artifactName": "PearNet-v2-windows-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.png",
      "shortcutName": "PearNet"
    }
  },
  "keywords": [],
  "author": {
    "name": "PearNet",
    "email": "fa4891922@gmail.com"
  },
  "homepage": "https://pearnet-frontend.onrender.com",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
