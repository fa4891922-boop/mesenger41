{
  "name": "pearnet-desktop",
  "version": "1.0.0",
  "description": "PearNet Messenger — Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently --kill-others \"cd ../frontend && npm run dev\" \"NODE_ENV=development electron .\"",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build": "electron-builder --linux --win"
  },
  "build": {
    "appId": "com.pearnet.messenger",
    "productName": "PearNet",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "icon.png"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    },
    "win": {
      "target": [
        { "target": "zip", "arch": ["x64"] }
      ],
      "icon": "icon.png",
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [],
  "author": {
    "name": "PearNet",
    "email": "fa4891922@gmail.com"
  },
  "homepage": "https://pearnet-frontend.onrender.com",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
