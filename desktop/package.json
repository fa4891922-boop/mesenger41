{
  "name": "pearnet-desktop",
  "version": "1.0.0",
  "description": "PearNet Messenger — Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build": "electron-builder --linux --win"
  },
  "build": {
    "appId": "com.pearnet.messenger",
    "productName": "PearNet",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "icon.png"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network"
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [],
  "author": "PearNet",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
